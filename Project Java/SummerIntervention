package Information_System;

import javax.swing.*;
import javax.swing.table.DefaultTableModel;
import java.io.*;
import java.awt.*;

public class study extends JFrame{
	
	private final JTextField studentID = new JTextField();
	private final JTextField firstName = new JTextField();
	private final JTextField lastName = new JTextField();
	private final JTextField course = new JTextField();
	private final JTextField yearLevel = new JTextField();
	private final JTextField midtermGrade = new JTextField();
	private final JTextField finalGrade = new JTextField();
	
	private final Object[] column = {"Student ID", "First Name", "Last Name", "Course", "Year Level", "Midterm Grade", "Final Grade"};
	
	private final DefaultTableModel model = new DefaultTableModel(column, 0);
	private final JTable table = new JTable(model);
	private final String FILE = "student.txt";
	
	public study() {
		setTitle("Student Information System");
		setSize(820,520);
		setDefaultCloseOperation(EXIT_ON_CLOSE);
		setLayout(new BorderLayout(10,10));
		setLocationRelativeTo(null);
		
		add(new JScrollPane(table), BorderLayout.CENTER);
		table.getSelectionModel().addListSelectionListener(e -> fillFields());
		
		JPanel inputs = new JPanel(new GridLayout(7,2,5,5));
		inputs.setBorder(BorderFactory.createTitledBorder("Details:"));
		inputs.add(new JLabel("Student ID"));
		inputs.add(studentID);
		inputs.add(new JLabel ("First Name"));
		inputs.add(firstName);
		inputs.add(new JLabel ("Last Name"));
		inputs.add(lastName);
		inputs.add(new JLabel ("Course"));
		inputs.add(course);
		inputs.add(new JLabel ("Year Level"));
		inputs.add(yearLevel);
		inputs.add(new JLabel ("Midterm Grades"));
		inputs.add(midtermGrade);
		inputs.add(new JLabel ("Final Grade"));
		inputs.add(finalGrade);
		
		JPanel buttons = new JPanel();
		addButton(buttons, "Add", e -> addRecord());
		addButton(buttons, "Update", e -> updateRecord());
		addButton(buttons, "Delete", e -> deleteRecord());
		addButton(buttons, "Clear", e -> clearFields());
		addButton(buttons, "Exit", e -> System.exit(0));
		
		JPanel bottom = new JPanel(new BorderLayout());
		bottom.add(inputs, BorderLayout.CENTER);
		bottom.add(buttons, BorderLayout.SOUTH);
		add(bottom, BorderLayout.SOUTH);
		
		loadFromFile();
	}
	
	private void addButton(JPanel p, String name, java.awt.event.ActionListener a) {
		JButton b = new JButton(name);
		b.addActionListener(a);
		p.add(b);
	}
	
	private Object[] readFields() {
		
		String ID = studentID.getText().trim();
		String First = firstName.getText().trim();
		String Last = lastName.getText().trim();
		String Course = course.getText().trim();
		String Year = yearLevel.getText().trim();
		String Midterm = midtermGrade.getText().trim();
		String Final = finalGrade.getText().trim();
		
		if(ID.isEmpty() || First.isEmpty() || Last.isEmpty() || Course.isEmpty() || Year.isEmpty() || Midterm.isEmpty() || Final.isEmpty()) {
			JOptionPane.showMessageDialog(this, "Please fill all fields!");
			return null;
		}
		try {
			int mid = Integer.parseInt(Midterm);
			int finale = Integer.parseInt(Final);
			return new Object[] {ID, First, Last, Course, Year, mid, finale};
		}catch (NumberFormatException ex) {
			JOptionPane.showMessageDialog(this, "Midterm Grade and Finals must be Numbers");
			return null;
		}
		
	}
	
	private void addRecord() {
		Object[] rows = readFields();
		if(rows != null) {
			model.addRow(rows);
			saveToFile();
			clearFields();
		}
	}
	
	private void updateRecord() {
		int row = table.getSelectedRow();
		if(row == -1) {
			JOptionPane.showMessageDialog(this, "Please select a record!");
			return;
		}
		Object[] newRow = readFields();
		if(newRow != null) {
			model.removeRow(row);
			model.insertRow(row, newRow);
			saveToFile();
			clearFields();
		}
	}
	
	private void deleteRecord() {
		int row = table.getSelectedRow();
		if(row == -1) {
			JOptionPane.showMessageDialog(this, "Please select a record!");
			return;
		}
		model.removeRow(row);
		saveToFile();
		clearFields();
	}
	
	private void clearFields() {
		studentID.setText("");
		firstName.setText("");
		lastName.setText("");
		course.setText("");
		yearLevel.setText("");
		midtermGrade.setText("");
		finalGrade.setText("");
	}
	
	private void fillFields() {
		int row = table.getSelectedRow();
		if(row == -1) {
			return;
		}
		studentID.setText(model.getValueAt(row, 0).toString());
		firstName.setText(model.getValueAt(row, 1).toString());
		lastName.setText(model.getValueAt(row, 2).toString());
		course.setText(model.getValueAt(row, 3).toString());
		yearLevel.setText(model.getValueAt(row, 4).toString());
		midtermGrade.setText(model.getValueAt(row, 5).toString());
		finalGrade.setText(model.getValueAt(row, 6).toString());
	}
	
	private void saveToFile() {
		try(PrintWriter write = new PrintWriter(new FileWriter(FILE))) {
			for(int items = 0; items < model.getRowCount(); items++ ) {
				write.println(model.getValueAt(items, 0) + ","
						+ model.getValueAt(items, 1) + ","
						+ model.getValueAt(items, 2)
						+ model.getValueAt(items, 3) + ","
						+ model.getValueAt(items, 4) + ","
						+ model.getValueAt(items, 5) + ","
						+ model.getValueAt(items, 6) + ",");
			}
		}catch (IOException e) {
			JOptionPane.showMessageDialog(this, "Error: " + e);
			return;
		}
	}
	
	private void loadFromFile() {
		try(BufferedReader br = new BufferedReader(new FileReader(FILE))) {
			String line;
			while((line = br.readLine()) != null) {
				String[] parts = line.split(",");
				if(parts.length == 7) {
					model.addRow(parts);
				}
			}
		}catch (IOException e1) {
			JOptionPane.showMessageDialog(this, "Error File: " + e1);
			return;
		}
	}

	public static void main(String[] args) {
		new study().setVisible(true);
	}

}
